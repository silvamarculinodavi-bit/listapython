def calcular_imc(p, a):
    imc = p / (a ** 2)
    return imc
def obeso_ou_nao(gordo):
     if gordo <= 25:
          return("NORMAL")
     else:
          return("ACIMA DO PESO")
def gerar_aviso(status):
    if status == "NORMAL":
         return("Parabéns! Continue mantendo hábitos saudáveis.")
    elif status == "ACIMA DO PESO":
          return("Procure praticar atividades físicas e manter uma alimentação equilibrada.")
peso = float(input("Digite seu peso em kg:"))
altura = float(input("Digite sua altura em metros:"))
imc_calculado = calcular_imc(peso, altura)
status_imc = obeso_ou_nao(imc_calculado)
aviso = gerar_aviso(status_imc)
print(f"Seu IMC é:{imc_calculado:.2f}")
print(f"status: {status_imc}")
print(f"aviso: {aviso}")